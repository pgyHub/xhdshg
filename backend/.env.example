# 复制为 .env 后按需修改（.env 勿提交到 Git）

# —— PostgreSQL 示例（本机）——
# DATABASE_URL=postgresql://用户名:密码@127.0.0.1:5432/数据库名
# 密码含特殊字符时请做 URL 编码，例如 @ → %40

# DATABASE_URL=postgresql://postgres:你的密码@localhost:5432/xiaohongdian

# —— 默认：SQLite（无需安装 PostgreSQL）——
DATABASE_URL=sqlite:///./xiaohongdian.db

SECRET_KEY=请换成随机长字符串
ACCESS_TOKEN_EXPIRE_MINUTES=30

# 生产必填：逗号分隔的前端域名，例如 https://www.example.com,https://example.com
# 开发可留空或填 *（此时浏览器跨域不携带 Cookie，与本项目 JWT 头方式兼容）
# CORS_ORIGINS=*

# 单文件上传最大字节（默认 10MB）
# MAX_UPLOAD_BYTES=10485760
